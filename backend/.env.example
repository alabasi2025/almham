DATABASE_URL=postgresql://user:password@localhost:5432/almham
PORT=3000

# Auth (generate a random 64-char hex string for production)
JWT_SECRET=change-this-to-a-long-random-string-in-production
JWT_EXPIRES_IN=12h
SESSION_COOKIE_NAME=almham_session
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_SAME_SITE=Lax
# Optional in production when frontend/backend share a parent domain.
# SESSION_COOKIE_DOMAIN=.example.com
SESSION_COOKIE_PATH=/

# Login rate limiting
LOGIN_RATE_LIMIT_WINDOW_MS=900000
LOGIN_RATE_LIMIT_MAX_FAILED=5
LOGIN_RATE_LIMIT_BLOCK_MS=900000
LOGIN_RATE_LIMIT_MAX_KEYS=2000

# Optional: used only when seeding real users locally.
# Never commit a real password in .env files.
# SEED_DEFAULT_USER_PASSWORD=
# SEED_RESET_USER_PASSWORDS=false
