BILLING_DATABASE_URL=postgresql://user:password@localhost:5432/almham_billing_db
BILLING_PORT=3100

# Temporary local-only protection until full JWT login is restored.
# Set BILLING_DEV_AUTH_DISABLED=true only on a trusted local machine.
BILLING_DEV_AUTH_DISABLED=false
BILLING_API_TOKEN=

# Static ECAS CSV snapshot used by ETL tools.
BILLING_ECAS_DATA_DIR=../../imports/ecas-data
