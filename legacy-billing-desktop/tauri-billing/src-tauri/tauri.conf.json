{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "ECAS Legacy Billing",
  "version": "0.1.0",
  "identifier": "com.alabasi.ecaslegacybilling",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://127.0.0.1:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "نظام الفوترة القديم ECAS",
        "width": 1440,
        "height": 900,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "externalBin": [
      "binaries/ecas-billing-api"
    ],
    "icon": [
      "icons/icon.ico"
    ]
  }
}
