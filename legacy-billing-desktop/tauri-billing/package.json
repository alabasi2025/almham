{
  "name": "ecas-legacy-billing-tauri",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --host 127.0.0.1 --port 1420",
    "build": "tsc && vite build",
    "preview": "vite preview --host 127.0.0.1 --port 1420",
    "api": "dotnet run --project ..\\src\\EcasLegacyBilling.Api\\EcasLegacyBilling.Api.csproj",
